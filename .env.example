# === OBRIGATÓRIAS ===
# Chave da API OpenAI
OPENAI_API_KEY=
# Caminho pro JSON da service account do Google Calendar
GOOGLE_SERVICE_ACCOUNT_PATH=

# Seu número do WhatsApp (formato: 5511999999999, sem + ou espaços)
OWNER_NUMBER=5511999999999

# Identificacao do seu WhatsApp (JID) - opcional, mas recomendado para evitar problemas de autenticação caso o bot nao te reconheca
OWNER_JID=

# === OPCIONAIS (já têm valor padrão) ===

# Porta do servidor HTTP interno
PORT=3001

# Token secreto pra autenticar chamadas internas
INTERNAL_TOKEN=

# Região AWS
AWS_REGION=us-east-1

# Nome da tabela DynamoDB
DYNAMODB_TABLE=
# Modelo OpenAI
OPENAI_MODEL=gpt-5.4-mini

# Máximo de mensagens no histórico por conversa
MAX_HISTORY=20